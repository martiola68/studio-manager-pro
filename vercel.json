{
  "buildCommand": "next build",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/scadenze/processa",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scadenze/processa-scadenzari",
      "schedule": "5 8 * * *"
    }
  ]
}
"crons": [
  {
    "path": "/api/scadenze/processa",
    "schedule": "0 8 * * *"
  },
  {
    "path": "/api/scadenze/processa-scadenzari",
    "schedule": "5 8 * * *"
  },
  {
    "path": "/api/antiriciclaggio/scadenze-verifica/send-alerts?secret=123",
    "schedule": "10 8 * * *"
  }
]
